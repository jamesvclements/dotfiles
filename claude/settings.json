{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Read(node_modules/**)",
      "Read(*/node_modules/**)",
      "Edit",
      "Write",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git remote *)",
      "Bash(git fetch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git stash *)",
      "Bash(git rev-parse *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm install *)",
      "Bash(pnpm run *)",
      "Bash(pnpm test *)",
      "Bash(pnpm install *)",
      "Bash(yarn run *)",
      "Bash(yarn test *)",
      "Bash(yarn install *)",
      "Bash(tree *)",
      "Bash(open *)",
      "Bash(gh *)",
      "Bash(claude *)",
      "Bash(agent-browser *)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.ssh/*)",
      "Read(**/.secrets/*)",
      "Read(**/secrets/*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(sudo rm -rf *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(rm *)",
      "Bash(docker *)"
    ]
  },
  "enabledPlugins": {
    "figma@claude-plugins-official": true,
    "vercel@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true,
  "model": "opus[1m]"
}
